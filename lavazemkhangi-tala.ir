    "infrastructure/docker/php/Dockerfile": """FROM python:3.10-slim

RUN apt-get update && apt-get install -y \\
    gcc \\
    postgresql-client \\
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
""",

    "infrastructure/docker/nginx/default.conf": """server {
    listen 80;
    server_name localhost;

    root /app;
    index index.html;

    location / {
        proxy_pass http://web:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /static/ {
        alias /app/static/;
    }

    location /media/ {
        alias /app/media/;
    }
}
""",

    # ==========================================
    # قالب‌های HTML
    # ==========================================
    "templates/base.html": """<!DOCTYPE html>
<html dir="rtl" lang="fa">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}قیمت‌یاب هوشمند{% endblock %}</title>
    <style>
        body { font-family: Tahoma, Arial, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; }
        .container { max-width: 1200px; margin: 0 auto; }
        .header { background: #fff; padding: 20px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .product-card { background: #fff; padding: 15px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .product-card img { max-width: 100%; height: 150px; object-fit: contain; }
        .price { color: #e53935; font-size: 18px; font-weight: bold; }
        .shop-name { color: #666; font-size: 14px; }
        .lowest-price { background: #4caf50; color: #fff; padding: 3px 10px; border-radius: 5px; }
        .pagination { margin-top: 20px; text-align: center; }
        .pagination a { margin: 0 5px; padding: 5px 10px; background: #fff; border-radius: 5px; text-decoration: none; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🏷️ قیمت‌یاب هوشمند</h1>
            <p>مقایسه قیمت از فروشگاه‌های معتبر</p>
        </div>
        {% block content %}{% endblock %}
    </div>
</body>
</html>
""",

    "templates/products/product_list.html": """{% extends 'base.html' %}
{% block title %}لیست محصولات{% endblock %}
{% block content %}
    <div class="product-grid">
        {% for product in products %}
        <div class="product-card">
            <a href="{% url 'product_detail' product.slug %}">
                {% if product.image %}
                <img src="{{ product.image }}" alt="{{ product.name }}">
                {% else %}
                <div style="height:150px;background:#eee;display:flex;align-items:center;justify-content:center;">بدون تصویر</div>
                {% endif %}
                <h3>{{ product.name|truncatechars:50 }}</h3>
                {% with cheapest=product.prices.all|dictsort:"price"|first %}
                    {% if cheapest %}
                    <div class="price">{{ cheapest.price }} تومان</div>
                    <div class="shop-name">فروشگاه: {{ cheapest.shop.name }}</div>
                    {% else %}
                    <div style="color:#999;">قیمت موجود نیست</div>
                    {% endif %}
                {% endwith %}
            </a>
        </div>
        {% empty %}
        <p>محصولی یافت نشد.</p>
        {% endfor %}
    </div>

    <div class="pagination">
        {% if page_obj.has_previous %}
        <a href="?page={{ page_obj.previous_page_number }}">قبلی</a>
        {% endif %}
        <span>صفحه {{ page_obj.number }} از {{ page_obj.paginator.num_pages }}</span>
        {% if page_obj.has_next %}
        <a href="?page={{ page_obj.next_page_number }}">بعدی</a>
        {% endif %}
    </div>
{% endblock %}
""",

    "templates/products/product_detail.html": """{% extends 'base.html' %}
{% block title %}{{ product.name }}{% endblock %}
{% block content %}
    <div style="background:#fff;padding:20px;border-radius:10px;">
        <h2>{{ product.name }}</h2>
        {% if product.image %}
        <img src="{{ product.image }}" style="max-width:300px;">
        {% endif %}
        <p>{{ product.description }}</p>

        <h3>💰 مقایسه قیمت</h3>
        <table style="width:100%;border-collapse:collapse;">
            <tr style="background:#f0f0f0;">
                <th>فروشگاه</th>
                <th>قیمت</th>
                <th>وضعیت</th>
            </tr>
            {% for price in prices %}
            <tr>
                <td>{{ price.shop.name }}</td>
                <td style="font-weight:bold;color:#e53935;">{{ price.price }} تومان</td>
                <td>{% if price.is_available %}✅ موجود{% else %}❌ ناموجود{% endif %}</td>
            </tr>
            {% empty %}
            <tr><td colspan="3">قیمتی ثبت نشده است</td></tr>
            {% endfor %}
        </table>

        <div style="margin-top:20px;">
            <a href="{% url 'product_list' %}" style="display:inline-block;padding:10px 20px;background:#2196f3;color:#fff;text-decoration:none;border-radius:5px;">← بازگشت به لیست</a>
        </div>
    </div>
{% endblock %}
""",

    # ==========================================
