#!/usr/bin/env python3
"""
Super Installer - قیمت‌یاب هوشمند
این اسکریپت تمام فایل‌ها را در جای خود می‌سازد و پروژه را راه‌اندازی می‌کند.
"""

import os
import sys
import subprocess
from pathlib import Path

# ============================================
# 1. تعریف مسیرها و محتوای فایل‌ها
# ============================================

FILES = {
    # ==========================================
    # فایل‌های ریشه (Root)
    # ==========================================
    "docker-compose.yml": """version: '3.8'

services:
  db:
    image: postgres:15
    environment:
      POSTGRES_DB: pricefinder
      POSTGRES_USER: user
      POSTGRES_PASSWORD: password
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    restart: unless-stopped

  redis:
    image: redis:7
    ports:
      - "6379:6379"
    restart: unless-stopped

  web:
    build:
      context: .
      dockerfile: infrastructure/docker/php/Dockerfile
    volumes:
      - .:/app
    ports:
      - "8000:8000"
    depends_on:
      - db
      - redis
    environment:
      - DJANGO_SETTINGS_MODULE=pricefinder.settings
    command: python manage.py runserver 0.0.0.0:8000
    restart: unless-stopped

  worker:
    build:
      context: .
      dockerfile: infrastructure/docker/php/Dockerfile
    volumes:
      - .:/app
    depends_on:
      - db
      - redis
    environment:
      - DJANGO_SETTINGS_MODULE=pricefinder.settings
    command: celery -A pricefinder worker --loglevel=info
    restart: unless-stopped

  beat:
    build:
      context: .
      dockerfile: infrastructure/docker/php/Dockerfile
    volumes:
      - .:/app
    depends_on:
      - db
      - redis
    environment:
      - DJANGO_SETTINGS_MODULE=pricefinder.settings
    command: celery -A pricefinder beat --loglevel=info
    restart: unless-stopped

volumes:
  postgres_data:
""",

    "auto-setup.sh": """#!/bin/bash
set -e

echo "🚀 راه‌اندازی خودکار پروژه pricefinder.ai..."

if ! command -v docker &> /dev/null; then
    echo "❌ Docker نصب نیست! لطفاً ابتدا Docker را نصب کنید."
    exit 1
fi

if command -v docker-compose &> /dev/null; then
    COMPOSE_CMD="docker-compose"
else
    COMPOSE_CMD="docker compose"
fi

if [ ! -f .env ]; then
    echo "SECRET_KEY=your-secret-key-here" > .env
    echo "DEBUG=True" >> .env
    echo "DATABASE_URL=postgres://user:password@db:5432/pricefinder" >> .env
    echo "REDIS_URL=redis://redis:6379/0" >> .env
fi

$COMPOSE_CMD up -d --build

echo "✅ راه‌اندازی کامل شد!"
echo "🌐 وب‌سایت روی آدرس: http://localhost:8000"
echo "📋 برای مشاهده لاگ‌ها: $COMPOSE_CMD logs -f"
""",

