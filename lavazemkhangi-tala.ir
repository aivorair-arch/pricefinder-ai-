    ".github/workflows/auto-deploy.yml": """name: Auto Deploy

on:
  push:
    branches: [ main ]

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Run Docker Compose
        run: |
          docker compose up -d --build
      - name: Check service status
        run
